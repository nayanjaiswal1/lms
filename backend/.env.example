# ══════════════════════════════════════════════════════════════════════════════
# MindForge Backend — Environment Variables
# This is the subset of variables read directly by the Go server.
# Copy to backend/.env for running the Go server outside of Docker.
# The full project .env.example at the repo root is the authoritative reference.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://mindforge:change_me_strong_password@localhost:5432/mindforge_dev    # Required

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0             # Required

# ─── JWT / Session ────────────────────────────────────────────────────────────
JWT_SECRET=change_me_min_32_chars_random_secret_replace_this_value    # Required — min 32 bytes
COOKIE_SECRET=change_me_min_32_chars_random_secret_replace_this_too   # Required — min 32 bytes
ENCRYPTION_KEY=change_me_exactly_32bytes_AES256_key_replace_this!!    # Required — exactly 32 bytes

ACCESS_TOKEN_TTL=15m                           # Optional — default 15m
REFRESH_TOKEN_TTL=720h                         # Optional — default 720h
PASSWORD_RESET_TTL=30m                         # Optional — default 30m
EMAIL_VERIFICATION_TTL=24h                     # Optional — default 24h

# ─── Tenant ───────────────────────────────────────────────────────────────────
DEFAULT_ORG_ID=00000000-0000-0000-0000-000000000001    # Required

# ─── OAuth ────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=                              # Optional
GOOGLE_CLIENT_SECRET=                          # Optional
GITHUB_CLIENT_ID=                              # Optional
GITHUB_CLIENT_SECRET=                          # Optional
FRONTEND_URL=http://localhost:3000             # Required

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=localhost                            # Required
SMTP_PORT=1025                                 # Optional — use 1025 for local Mailpit
SMTP_USER=                                     # Optional in dev
SMTP_PASS=                                     # Optional in dev
EMAIL_FROM=noreply@mindforge.dev               # Optional

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080                                      # Optional — default 8080
ENV=development                                # Optional — "production" enables Secure cookies

# ─── Optional ─────────────────────────────────────────────────────────────────
MAXMIND_DB_PATH=                               # Optional — path to GeoLite2-City.mmdb
