# ══════════════════════════════════════════════════════════════════════════════
# MindForge — Production Environment Variables
# Copy this file to .env.prod and fill in ALL values before deploying.
# NEVER commit .env.prod — it is in .gitignore.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Domain ───────────────────────────────────────────────────────────────────
# Used by Caddy to obtain a TLS certificate via ACME (Let's Encrypt).
# Must be a real domain with DNS pointing to this server before deploying.

DOMAIN=app.yourdomain.com                      # Required — your production domain

# ─── Database ─────────────────────────────────────────────────────────────────
# Postgres runs inside Docker (no external port exposure).
# Use a strong, randomly generated password.

POSTGRES_USER=mindforge                        # Required
POSTGRES_PASSWORD=change_me_very_strong_prod_password    # Required — use openssl rand -hex 32
POSTGRES_DB=mindforge_prod                     # Required

DATABASE_URL=postgres://mindforge:change_me_very_strong_prod_password@postgres:5432/mindforge_prod    # Required

# ─── Redis ────────────────────────────────────────────────────────────────────
# Redis runs inside Docker (no external port exposure). Use a password in prod.

REDIS_PASSWORD=change_me_strong_redis_password    # Required in prod
REDIS_URL=redis://:change_me_strong_redis_password@redis:6379/0    # Required

# ─── JWT / Session ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# All three must be different, min 32 bytes, and NOT the same as dev values.

JWT_SECRET=change_me_prod_jwt_secret_min_32_bytes_random_string      # Required
COOKIE_SECRET=change_me_prod_cookie_secret_min_32_bytes_random_str   # Required
ENCRYPTION_KEY=change_me_prod_encryption_key_exactly_32bytes!!       # Required — exactly 32 bytes

ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
PASSWORD_RESET_TTL=30m
EMAIL_VERIFICATION_TTL=24h

# ─── Tenant ───────────────────────────────────────────────────────────────────
DEFAULT_ORG_ID=00000000-0000-0000-0000-000000000001    # Required

# ─── OAuth ────────────────────────────────────────────────────────────────────
# Callback URLs for production:
#   Google: https://app.yourdomain.com/api/auth/google/callback
#   GitHub: https://app.yourdomain.com/api/auth/github/callback

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

FRONTEND_URL=https://app.yourdomain.com        # Required — must match DOMAIN

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Use a transactional email provider: Postmark, Resend, SendGrid, SES, etc.
# For Postmark: SMTP_HOST=smtp.postmarkapp.com SMTP_PORT=587

SMTP_HOST=smtp.postmarkapp.com                 # Required
SMTP_PORT=587                                  # Optional — default 587
SMTP_USER=your_smtp_api_key_or_username        # Required
SMTP_PASS=your_smtp_api_key_or_password        # Required
EMAIL_FROM=noreply@yourdomain.com              # Required — must be verified with your provider

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
ENV=production                                 # Required — enables Secure cookies, strict logging

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://app.yourdomain.com    # Required — public backend URL
NEXT_PUBLIC_APP_URL=https://app.yourdomain.com    # Required — public frontend URL
BACKEND_URL=http://backend:8080                    # Server-to-server (uses internal Docker hostname)

# ─── Optional features ────────────────────────────────────────────────────────
MAXMIND_DB_PATH=/app/GeoLite2-City.mmdb        # Optional — mount the file into the backend container
