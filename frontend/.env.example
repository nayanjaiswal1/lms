# ─────────────────────────────────────────────
# MindForge frontend environment
# Copy to .env.local and fill in. NEXT_PUBLIC_* values are exposed to the browser.
# ─────────────────────────────────────────────

# Public origin of the Go backend API (used by lib/server/features.ts and
# server actions). No trailing slash. Required — feature gating returns empty
# (everything locked) if this is unset.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Public origin of this Next.js app. Used as metadataBase for absolute OG/canonical URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-to-server backend URL — used in server actions and route handlers.
# This is NOT exposed to the browser (no NEXT_PUBLIC_ prefix).
# In Docker prod, this points to the internal service name: http://backend:8080
BACKEND_URL=http://localhost:8080

# Anthropic API key — used server-side only for resume parsing (never exposed to browser)
ANTHROPIC_API_KEY=
