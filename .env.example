# ══════════════════════════════════════════════════════════════════════════════
# MindForge — Development Environment Variables
# Copy this file to .env and fill in all required values before running make dev
# ══════════════════════════════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────────────────────────────
# Credentials used by both docker-compose (to create the Postgres container)
# and the Go backend (to connect).

POSTGRES_USER=mindforge                        # Required — Postgres superuser name
POSTGRES_PASSWORD=change_me_strong_password    # Required — Postgres superuser password
POSTGRES_DB=mindforge_dev                      # Required — Database name

# Full DSN consumed by the Go backend via pgx/v5.
# Must match the values above.
DATABASE_URL=postgres://mindforge:change_me_strong_password@localhost:5432/mindforge_dev

# ─── Redis ────────────────────────────────────────────────────────────────────
# No password in dev (Redis runs with --save "" — no persistence).
# In production, add ?password=<REDIS_PASSWORD> or set REDIS_PASSWORD separately.

REDIS_URL=redis://localhost:6379/0             # Required — Redis connection URL
REDIS_PASSWORD=                                # Optional in dev; required in prod

# ─── Code execution (coding-question auto-grading) ────────────────────────────
# Optional. When JUDGE0_URL is unset, coding answers are left pending for manual
# grading and MCQ auto-grading is unaffected. Point at a self-hosted Judge0 CE.
JUDGE0_URL=                                    # e.g. http://localhost:2358
JUDGE0_TOKEN=                                  # Optional X-Auth-Token for Judge0
JUDGE0_TIMEOUT=30s                             # Per-run execution budget

# ─── JWT / Session ────────────────────────────────────────────────────────────
# All three secrets must be at least 32 bytes of random data.
# Generate with: openssl rand -hex 32

JWT_SECRET=change_me_min_32_chars_random_secret_replace_this_value    # Required — signs access tokens (HS256)
COOKIE_SECRET=change_me_min_32_chars_random_secret_replace_this_too   # Required — signs OAuth state cookies
ENCRYPTION_KEY=change_me_exactly_32bytes_AES256_key_replace_this!!    # Required — exactly 32 bytes, AES-256-GCM

# Token lifetimes (Go duration format: 15m, 1h, 720h)
ACCESS_TOKEN_TTL=15m                           # Optional — default 15m
REFRESH_TOKEN_TTL=720h                         # Optional — default 720h (30 days)
PASSWORD_RESET_TTL=30m                         # Optional — default 30m
EMAIL_VERIFICATION_TTL=24h                     # Optional — default 24h

# ─── Tenant ───────────────────────────────────────────────────────────────────
# The default org that self-registered users are assigned to.
# Seeded in migration 001_init.sql — do not change this UUID unless you reseed.

DEFAULT_ORG_ID=00000000-0000-0000-0000-000000000001    # Required

# ─── OAuth ────────────────────────────────────────────────────────────────────
# Create OAuth apps at:
#   Google: https://console.cloud.google.com/apis/credentials
#   GitHub: https://github.com/settings/developers
# Callback URLs:
#   Google: http://localhost:3000/api/auth/google/callback
#   GitHub: http://localhost:3000/api/auth/github/callback

GOOGLE_CLIENT_ID=                              # Optional — leave blank to disable Google OAuth
GOOGLE_CLIENT_SECRET=                          # Optional

GITHUB_CLIENT_ID=                              # Optional — leave blank to disable GitHub OAuth
GITHUB_CLIENT_SECRET=                          # Optional

FRONTEND_URL=http://localhost:3000             # Required — redirect target after OAuth callback

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# For dev, use Mailpit (https://github.com/axllent/mailpit) or Mailtrap.
# Mailpit: docker run -p 1025:1025 -p 8025:8025 axllent/mailpit
# Then set SMTP_HOST=localhost SMTP_PORT=1025 SMTP_USER="" SMTP_PASS=""

SMTP_HOST=localhost                            # Required — SMTP server hostname
SMTP_PORT=1025                                 # Optional — default 587 (use 1025 for Mailpit)
SMTP_USER=                                     # Required in prod — SMTP auth username
SMTP_PASS=                                     # Required in prod — SMTP auth password
EMAIL_FROM=noreply@mindforge.dev               # Optional — sender address

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080                                      # Optional — Go server port, default 8080
ENV=development                                # Optional — "production" enables Secure cookies + strict logging

# ─── Frontend ─────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_* values are embedded in the browser bundle. Never put secrets here.

NEXT_PUBLIC_API_URL=http://localhost:8080      # Required — backend URL exposed to browser
NEXT_PUBLIC_APP_URL=http://localhost:3000      # Required — frontend public URL for OG/canonical tags
BACKEND_URL=http://localhost:8080              # Optional — server-to-server URL (not in browser bundle)

# ─── Optional features ────────────────────────────────────────────────────────
# Download GeoLite2-City.mmdb from https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
# Enables impossible-travel detection on login (flags logins from distant locations within short time).

MAXMIND_DB_PATH=                               # Optional — path to GeoLite2-City.mmdb
